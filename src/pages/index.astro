---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/landing/Hero.astro';
import Intro from '../components/landing/Intro.astro';
import Differentiators from '../components/landing/Differentiators.astro';
import Technology from '../components/landing/Technology.astro';
import Applications from '../components/landing/Applications.astro';
import Team from '../components/landing/Team.astro';
import ContactCTA from '../components/landing/ContactCTA.astro';

const title = 'ROBOSECT — AI Robotics for Cable & Wiring Harness Automation';
const description =
	'ROBOSECT builds AI robots with computer vision and motion planning to automate manipulation, assembly, inspection and testing of cables and wiring harnesses.';
---

<BaseLayout title={title} description={description}>
	<Hero />
	<Intro />
	<Differentiators />
	<Technology />
	<Applications />
	<Team />
	<ContactCTA />
</BaseLayout>
