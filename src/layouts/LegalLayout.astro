---
import BaseLayout from './BaseLayout.astro';

interface Props {
	title: string;
	description: string;
	lastUpdated: string;
}

const { title, description, lastUpdated } = Astro.props;
---

<BaseLayout title={`${title} · ROBOSECT`} description={description}>
	<article class="legal">
		<div class="container">
			<a href="/" class="back-link">&larr; Back to home</a>
			<header>
				<h1>{title}</h1>
				<time>Last updated: {lastUpdated}</time>
			</header>
			<div class="prose">
				<slot />
			</div>
		</div>
	</article>
</BaseLayout>

<style>
	.legal {
		padding-top: 4em;
		padding-bottom: 4em;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 2em;
		color: var(--color-fg-light);
	}

	header {
		margin-bottom: 2em;
	}

	time {
		display: block;
		font-size: 0.85em;
		color: var(--color-fg-light);
		margin-top: 0.5em;
	}

	.prose {
		max-width: 42em;
		text-align: justify;
	}

	.prose :global(h2) {
		font-size: 1.4em;
		margin-top: 1.8em;
	}

	.prose :global(ul) {
		padding-left: 1.2em;
		margin: 0 0 1em 0;
	}

	.prose :global(li) {
		margin-bottom: 0.4em;
	}
</style>
