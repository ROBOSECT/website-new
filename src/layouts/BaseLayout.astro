---
import { getImage } from 'astro:assets';
import SiteFooter from '../components/landing/SiteFooter.astro';
import NavBar from '../components/landing/NavBar.astro';
import iconaV2 from '../assets/images/icona_v2.png';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/600.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ROBOSECT',
  description = 'ROBOSECT develops AI-powered robotic systems combining computer vision and motion planning to automate the manipulation, assembly, inspection and testing of cables, wiring harnesses and other deformable industrial products.',
} = Astro.props;

const favicon32 = await getImage({ src: iconaV2, width: 32, height: 32, format: 'png' });
const favicon180 = await getImage({ src: iconaV2, width: 180, height: 180, format: 'png' });
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/png" sizes="32x32" href={favicon32.src} />
		<link rel="apple-touch-icon" href={favicon180.src} />
		<title>{title}</title>
	</head>
	<body>
		<NavBar />
		<slot />
		<SiteFooter />
	</body>
</html>
