---
const applications = [
	{
		title: 'Automatic Electrical Panel Testing',
		text: 'Robotic quality control platform for autonomous electrical continuity verification of industrial switchboards.',
		list: [
			'AI component recognition',
			'CAD integration',
			'Automatic test generation',
			'Digital reports',
			'Complete traceability',
		],
		project: 'CONTEST project',
	},
	{
		title: 'Wiring Harness Automation',
		text: 'Robotic manipulation, assembly and remanufacturing of automotive wiring harnesses through multimodal perception, AI planning and collaborative robotics.',
	},
	{
		title: 'Intelligent Motion Planning',
		text: 'Real-time collision-free robot trajectory planning considering cables, dress packs and deformable objects.',
	},
	{
		title: 'Custom AI Robotics',
		text: 'Development of tailored robotic solutions for manufacturers requiring:',
		list: [
			'Deformable object manipulation',
			'Industrial AI',
			'Robotic inspection',
			'Intelligent automation',
			'Collaborative robotics',
		],
	},
];
---

<section id="applications" class="applications alt">
	<div class="container">
		<header class="text-center">
			<span class="eyebrow">Use Cases</span>
			<h2>Applications</h2>
		</header>
		<div class="app-grid">
			{
				applications.map((a) => (
					<div class="app-card">
						<h3>{a.title}</h3>
						<p>{a.text}</p>
						{a.list && (
							<ul>
								{a.list.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						)}
						{a.project && <p class="project-tag">{a.project}</p>}
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.app-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2.5em;
		margin-top: 3em;
	}

	@media (max-width: 780px) {
		.app-grid {
			grid-template-columns: 1fr;
		}
	}

	.app-card {
		background: var(--color-bg);
		padding: 2em;
		border: 1px solid var(--color-border-bg);
		border-radius: var(--border-radius);
		transition:
			transform 0.2s ease,
			border-color 0.2s ease;
	}

	.app-card:hover {
		transform: translateY(-4px);
		border-color: var(--color-border);
	}

	.app-card h3 {
		color: var(--color-accent-blue);
	}

	.app-card ul {
		margin: 0.5em 0 1em;
		padding-left: 1.2em;
	}

	.app-card li {
		margin-bottom: 0.3em;
	}

	.project-tag {
		display: inline-block;
		margin: 0.5em 0 0;
		padding: 0.3em 0.7em;
		border: 1px solid var(--color-border-bg);
		border-radius: var(--border-radius);
		font-family: var(--font-family-mono);
		font-size: 0.75em;
		font-weight: 500;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--color-fg-light);
	}
</style>
